{
  "name": "dueterium-ui",
  "version": "0.1.0",
  "description": "Dueterium is a minimalist, expressive Svelte component library built for fast development and beautiful layouts. Open to everyone, built for anything.",
  "type": "module",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "import": "./dist/dueterium-ui.es.js",
      "require": "./dist/dueterium-ui.cjs.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.35.5",
    "svelte-check": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "keywords": ["svelte", "ui", "component-library", "dueterium", "neo", "barter"],
  "author": "Suraadyksha",
  "license": "MIT"
}