{
  "name": "dueterium-ui",
  "version": "0.1.0",
  "description": "Dueterium is a minimalist, expressive Svelte component library built for fast development and beautiful layouts. Open to everyone, built for anything.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
  ".": {
    "svelte": "./src/index.ts",
    "import": "./dist/dueterium-ui.es.js",
    "require": "./dist/dueterium-ui.cjs.js"
  }
},
  "files": ["dist", "src"],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc"
  },
  "repository": {
    "type": "https://github.com/justice-programmer/dueterium.git"
  },
  "bugs": {
    "url": "https://github.com/justice-programmer/dueterium/issues"
  },
  "homepage": "https://github.com/justice-programmer/dueterium#readme",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.35.5",
    "svelte-check": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "keywords": [
    "svelte",
    "ui",
    "component-library",
    "dueterium"
  ],
  "author": "Suraadyksha",
  "license": "MIT"
}