{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["svelte"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "target": "ES2017",
    "moduleResolution": "Node",
    "lib": ["DOM", "ES2017"],
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

